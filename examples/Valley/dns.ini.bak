#Vector=<Gx,Gy,Gz>
#Parameters=<value>
Vector=0.0,1.0,0.0
Parameters=0.0018142362395104322
#
#[Rotation]
#Vector=<Fx,Fy,Fz>
#Parameters=<value>
#
#[Radiation]
#Scalar=<value>
#Parameters=<value>
