#VerbosityLevel=<0/1/2>
#Type=<temporal/spatial>
#CalculateFlow=<yes/no>
#CalculateScalar=<yes/no>
#Equations=<total/internal/incompressible/anelastic>
#TermAdvection=<divergence/skewsymmetric>
#TermViscous=<divergence/explicit>
#TermDiffusion=<divergence/explicit>
#TermBodyForce=<none/Explicit/Homogeneous/Linear/Bilinear/Quadratic>
#TermCoriolis=<none/explicit/normalized>
#TermRadiation=<none/Bulk1dGlobal/Bulk1dLocal>
#TermSubsidence=<none/ConstantDivergenceLocal/ConstantDivergenceGlobal>
#TermTransport=<constant/powerlaw/sutherland/Airwater/AirwaterSimplified>
#TermChemistry=<none/quadratic/layeredrelaxation/ozone>
#TermRandom=<value>
#SpaceOrder=<CompactJacobian4/CompactJacobian6/CompactJacobian6Penta/CompactDirect6>
#ComModeITranspose=<none,asynchronous,sendrecv>
#ComModeKTranspose=<none,asynchronous,sendrecv>
FileFormat=mpiio
FileType=double
VerbosityLevel=1
Type=temporal
CalculateFlow=yes
CalculateScalar=yes
Equations=incompressible
Mixture=none
TermAdvection=convective
TermViscous=explicit
TermDiffusion=explicit
TermBodyForce=homogeneous
TermCoriolis=none
TermRadiation=none
TermSubsidence=none
TermTransport=constant
TermChemistry=none
TermRandom=0.0
SpaceOrder=compactjacobian6
EllipticOrder=compactjacobian6
#
#[Staggering]
#StaggerHorizontalPressure=<yes/no>
StaggerHorizontalPressure=yes
#
#[Parameters]
#Reynolds=<value>
#Prandtl=<value>
#Froude=<value>
#Rossby=<value>
#Mach=<value>
#Gama=<value>
#Schmidt=<value>
#Damkohler=<value>
#Stokes=<value>
#Settling=<value>
