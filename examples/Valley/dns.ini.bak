#Imax(*)=<imax_proc>
#Jmax=<jmax>
#Kmax=<kmax>
#Kmax(*)=<kmax_proc>
#XUniform=<yes/no>
#YUniform=<yes/no>
#ZUniform=<yes/no>
#XPeriodic=<yes/no>
#YPeriodic=<yes/no>
#ZPeriodic=<yes/no>
